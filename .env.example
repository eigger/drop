POSTGRES_USER=drop
POSTGRES_PASSWORD=changeme
POSTGRES_DB=drop
POSTGRES_PORT=5433
DATABASE_URL=postgresql://drop:changeme@localhost:5433/drop

JWT_SECRET=changeme

# 리버스 프록시/터널 뒤에서 최종적으로 접속하는 공개 URL (https). 쿠키 Secure 플래그가
# 이 값을 기준으로 동작하지는 않지만, 로그 및 리다이렉트 기준값으로 사용한다.
APP_PUBLIC_URL=http://localhost

# 최초 관리자 계정은 회원가입 없이 웹 UI의 부트스트랩 화면에서 직접 생성한다 (User 테이블이
# 비어있을 때만 1회 허용).

# 업로드 저장 위치. 비워두면 apps/api/uploads(로컬 개발 기준)를 쓴다 — Docker Compose에서는
# docker-compose.yml이 컨테이너 내부 경로(/app/uploads)로 이 값을 직접 덮어쓰므로 여기서
# 설정할 필요 없다.
UPLOAD_DIR=

# 업로드 허용 최대 용량 (MB 단위, 파일 1개 기준). 웹 UI는 청크 업로드라 요청 하나의 메모리
# 사용량은 이 값과 무관하게 청크 크기(8MB)로 고정된다 — 넉넉하게 잡아도 안전하다.
FILE_SIZE_LIMIT_MB=10240
