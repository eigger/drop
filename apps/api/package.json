{
  "name": "@drop/api",
  "version": "0.4.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node --env-file=../../.env ../../node_modules/.bin/prisma migrate dev",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "@drop/shared": "*",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.0",
    "node-cron": "^4.6.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/archiver": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.15",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.39.5",
    "prisma": "^5.22.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
